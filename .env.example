# Copy this file to .env and fill in your values.
# .env is loaded automatically by ADK / google-genai / python-dotenv.

# Tells the Google GenAI SDK to call Vertex AI instead of looking
# for a consumer API key.
GOOGLE_GENAI_USE_VERTEXAI=TRUE

# Your GCP project and region.
GOOGLE_CLOUD_PROJECT=your-project-id
GOOGLE_CLOUD_LOCATION=us-central1

# Used by the deploy scripts.
PROJECT_ID=your-project-id
REGION=us-central1

# Set this AFTER you deploy the MCP server (deploy_mcp.sh prints it).
# Only needed by the HTTP agent.
# MCP_SERVER_URL=https://clinical-mcp-xxxxx-uc.a.run.app
